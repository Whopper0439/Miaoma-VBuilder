{
  "permissions": {
    "allowedTools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Glob",
      "Grep"
    ],
    "deniedTools": [],
    "allowedCommands": [
      "npm run *",
      "npm test",
      "npm install",
      "npx *",
      "yarn run *",
      "yarn test",
      "yarn add *",
      "pnpm run *",
      "pnpm test",
      "pnpm add *",
      "bun run *",
      "bun test",
      "git status",
      "git diff *",
      "git log *",
      "git add *",
      "git commit *",
      "git branch *",
      "git checkout *",
      "git switch *",
      "git stash *",
      "node *",
      "tsx *",
      "python *",
      "cargo test *",
      "cargo build *",
      "go test *",
      "go build *",
      "make *",
      "pnpm --filter *"
    ],
    "deniedCommands": [
      "rm -rf /",
      "rm -rf /*",
      "sudo rm -rf *",
      "git push --force",
      "git push -f",
      "git reset --hard",
      "git clean -fd",
      "docker system prune -a",
      "docker rm -f *",
      "DROP DATABASE *",
      "DROP TABLE *",
      "TRUNCATE *",
      "npm publish",
      "yarn publish",
      ":(){:|:&};:",
      "mkfs *",
      "dd if=*"
    ]
  },
  "behavior": {
    "autoFormat": true,
    "autoLint": true,
    "autoTest": false,
    "commitStyle": "conventional"
  }
}
